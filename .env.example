# MindCare Environment Variables

# Note: This app stores the API key in browser localStorage for security.
# You don't need to create a .env file - just add your API key in the Settings tab.

# To get your Groq API key:
# 1. Visit https://console.groq.com
# 2. Sign up/login
# 3. Go to API Keys
# 4. Create a new key
# 5. Add it in the app's Settings tab
VITE_GROQ_API_KEY=your_real_groq_api_key

# Your API key will be stored securely in your browser's localStorage
# and will only be sent to Groq AI servers for AI features.
